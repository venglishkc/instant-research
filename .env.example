# Cerebras Inference API key — https://cloud.cerebras.ai
CEREBRAS_API_KEY=your_cerebras_key_here

# Tavily web search API key — https://tavily.com (free tier is plenty)
TAVILY_API_KEY=your_tavily_key_here

# Optional model overrides (defaults shown)
CEREBRAS_PLANNER_MODEL=llama3.1-8b
CEREBRAS_WRITER_MODEL=llama-3.3-70b
